# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default
S3_BUCKET=your-address-validation-bucket
GLUE_DATABASE=address_validation_db

# SmartyStreets API Credentials
SMARTYSTREETS_AUTH_ID=your-auth-id-here
SMARTYSTREETS_AUTH_TOKEN=your-auth-token-here

# DynamoDB Cache
DYNAMODB_CACHE_TABLE=address_validation_cache
DYNAMODB_TTL_DAYS=90

# Processing Configuration
BATCH_SIZE=100
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2
CACHE_ENABLED=true

# Logging
LOG_LEVEL=INFO
